# Copy this file to .env.local and paste your Supabase project's values.
# Both are safe to expose to the browser (the anon key is protected by
# row-level security in the database). Without these, the app runs entirely on
# localStorage — no cloud, no accounts, no setup needed.
#
# Find them in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
